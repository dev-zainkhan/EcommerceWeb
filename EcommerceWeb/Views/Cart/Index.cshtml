@using CartModel = EcommerceWeb.Models.Cart.Cart
@model List<CartModel>

@{
    ViewBag.Title = "My Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa, #e4ecf5);
    }

    .cart-title {
        font-weight: bold;
        color: #2c3e50;
    }

    .cart-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        transition: 0.3s;
        background: white;
    }

        .cart-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.12);
        }

    .product-image {
        height: 140px;
        object-fit: cover;
        width: 100%;
    }

    .no-image {
        height: 140px;
        background: #6c757d;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    .card-title {
        font-weight: bold;
        color: #2d3436;
    }

    .price-text {
        font-size: 20px;
        font-weight: bold;
        color: #27ae60;
    }

    .quantity-box input {
        border-radius: 10px 0 0 10px;
    }

    .quantity-box button {
        border-radius: 0 10px 10px 0;
    }

    .btn-update {
        background: #0d6efd;
        color: white;
        border: none;
    }

        .btn-update:hover {
            background: #0b5ed7;
        }

    .btn-remove {
        border-radius: 10px;
        padding: 8px 15px;
        transition: 0.3s;
    }

        .btn-remove:hover {
            transform: scale(1.05);
        }

    .summary-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        position: sticky;
        top: 20px;
    }

    .summary-header {
        background: linear-gradient(45deg, #0d6efd, #3b82f6);
        color: white;
        padding: 18px;
    }

        .summary-header h5 {
            margin: 0;
            font-weight: bold;
        }

    .table td {
        vertical-align: middle;
        padding: 14px;
    }

    .checkout-btn {
        height: 50px;
        border-radius: 12px;
        font-weight: bold;
        font-size: 17px;
        transition: 0.3s;
    }

        .checkout-btn:hover {
            transform: translateY(-2px);
        }

    .continue-btn {
        height: 48px;
        border-radius: 12px;
        font-weight: 500;
    }

    .empty-cart {
        border-radius: 15px;
        padding: 20px;
        font-size: 18px;
    }

        .empty-cart a {
            font-weight: bold;
            text-decoration: none;
        }

            .empty-cart a:hover {
                text-decoration: underline;
            }
</style>

<div class="container py-5">

    <h2 class="cart-title mb-4">🛒 My Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info empty-cart shadow-sm">
            Your cart is empty.
            <a href="/Product/Index">Continue Shopping</a>
        </div>
    }
    else
    {
        <div class="row">

            <!-- Cart Items -->
            <div class="col-lg-8">

                @foreach (var item in Model)
                {
                    <div class="card cart-card mb-4 shadow-sm">

                        <div class="row g-0">

                            <div class="col-md-3">
                                @if (!string.IsNullOrEmpty(item.ImagePath))
                                {
                                    <img src="@item.ImagePath"
                                         class="product-image" />
                                }
                                else
                                {
                                    <div class="no-image">
                                        No Image
                                    </div>
                                }
                            </div>

                            <div class="col-md-9">

                                <div class="card-body">

                                    <div class="d-flex justify-content-between align-items-start">

                                        <div>
                                            <h5 class="card-title mb-2">
                                                @item.ProductName
                                            </h5>

                                            <p class="text-muted mb-1">
                                                Price:
                                                Rs. @item.Price.ToString("N0")
                                            </p>

                                            <p class="text-muted">
                                                Quantity:
                                                @item.Quantity
                                            </p>
                                        </div>

                                        <div class="price-text">
                                            Rs. @item.Subtotal.ToString("N0")
                                        </div>

                                    </div>

                                    <hr />

                                    <div class="d-flex flex-wrap gap-2">

                                        <!-- Update Quantity -->
                                        <form method="post"
                                              action="/Cart/UpdateQuantity">

                                            <input type="hidden"
                                                   name="cartId"
                                                   value="@item.CartId" />

                                            <div class="input-group quantity-box"
                                                 style="width:160px;">

                                                <input type="number"
                                                       name="quantity"
                                                       value="@item.Quantity"
                                                       min="1"
                                                       class="form-control" />

                                                <button type="submit"
                                                        class="btn btn-update">
                                                    Update
                                                </button>

                                            </div>

                                        </form>

                                        <!-- Remove -->
                                        <form method="post"
                                              action="/Cart/Remove">

                                            <input type="hidden"
                                                   name="cartId"
                                                   value="@item.CartId" />

                                            <button type="submit"
                                                    class="btn btn-danger btn-remove">
                                                🗑 Remove
                                            </button>

                                        </form>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">

                <div class="card summary-card shadow">

                    <div class="summary-header">
                        <h5>Order Summary</h5>
                    </div>

                    <div class="card-body">

                        <table class="table align-middle">

                            <tr>
                                <td>
                                    Items (@Model.Count)
                                </td>

                                <td class="text-end fw-bold">
                                    Rs. @Model.Sum(x => x.Subtotal).ToString("N0")
                                </td>
                            </tr>

                            <tr>
                                <td>Shipping</td>

                                <td class="text-end text-success fw-bold">
                                    Free
                                </td>
                            </tr>

                            <tr class="fw-bold">
                                <td>Total</td>

                                <td class="text-end text-success">
                                    Rs. @Model.Sum(x => x.Subtotal).ToString("N0")
                                </td>
                            </tr>

                        </table>

                        <a href="/Order/Checkout"
                               class="btn btn-success checkout-btn w-100">
                            Proceed to Checkout →
                        </a>

                        <a href="/Product/Index"
                               class="btn btn-outline-secondary continue-btn w-100 mt-3">
                            ← Continue Shopping
                        </a>

                    </div>

                </div>

            </div>

        </div>
    }

</div>