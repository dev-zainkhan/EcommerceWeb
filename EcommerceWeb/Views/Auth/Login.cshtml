@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-stretch g-4">
        <!-- Brand panel -->
        <div class="col-lg-5 d-none d-lg-block">
            <div class="auth-hero">
                <span class="badge bg-light text-dark mb-3">🛍️ ShopSphere</span>
                <h2 class="fw-bold">Welcome back.</h2>
                <p class="opacity-75 mt-2">Sign in to keep shopping, manage your store, and track your orders — all in one place.</p>
                <div class="feat"><span>⚡</span><span>Fast, secure checkout with cash on delivery</span></div>
                <div class="feat"><span>🔒</span><span>BCrypt-protected accounts</span></div>
                <div class="feat"><span>📦</span><span>Real-time stock &amp; multi-image listings</span></div>
            </div>
        </div>

        <!-- Form -->
        <div class="col-lg-5 col-md-7">
            <div class="card shadow h-100">
                <div class="card-body p-4 p-md-5 d-flex flex-column justify-content-center">
                    <h3 class="fw-bold mb-1">Sign in</h3>
                    <p class="text-muted mb-4">Enter your credentials to continue.</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }
                    <form method="post" action="/Auth/Login">
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" placeholder="you@example.com" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label">Password</label>
                            <input type="password" name="password" class="form-control" placeholder="••••••••" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100 btn-lg">Sign in</button>
                    </form>
                    <p class="text-center text-muted mt-4 mb-0">
                        Don't have an account? <a href="/Auth/Register" class="fw-semibold">Create one</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
