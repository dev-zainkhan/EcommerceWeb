@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        min-height: 100vh;
        overflow: hidden;
    }

    .login-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    .login-card {
        width: 100%;
        max-width: 430px;
        border: none;
        border-radius: 20px;
        overflow: hidden;
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.12);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        animation: fadeIn 1s ease;
    }

    .card-header {
        background: rgba(255, 255, 255, 0.15);
        border-bottom: none;
        padding: 25px;
    }

    .card-header h3 {
        font-weight: bold;
        margin: 0;
        color: white;
        letter-spacing: 1px;
    }

    .card-body {
        padding: 35px;
    }

    .form-label {
        color: white;
        font-weight: 500;
    }

    .form-control {
        height: 50px;
        border-radius: 12px;
        border: none;
        padding-left: 15px;
        background: rgba(255, 255, 255, 0.9);
        transition: 0.3s;
    }

    .form-control:focus {
        box-shadow: 0 0 10px rgba(255,255,255,0.7);
        transform: scale(1.02);
    }

    .btn-login {
        height: 50px;
        border-radius: 12px;
        font-size: 18px;
        font-weight: bold;
        background: linear-gradient(45deg, #00c6ff, #0072ff);
        border: none;
        transition: 0.3s;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,114,255,0.4);
    }

    .card-footer {
        background: transparent;
        border-top: none;
        text-align: center;
        padding-bottom: 25px;
        color: white;
    }

    .card-footer a {
        color: #00c6ff;
        text-decoration: none;
        font-weight: bold;
    }

    .card-footer a:hover {
        text-decoration: underline;
    }

    .alert {
        border-radius: 10px;
    }

    /* Floating circles background */
    .circle {
        position: absolute;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        animation: float 6s infinite ease-in-out;
    }

    .circle:nth-child(1) {
        width: 120px;
        height: 120px;
        top: 10%;
        left: 15%;
    }

    .circle:nth-child(2) {
        width: 180px;
        height: 180px;
        bottom: 10%;
        right: 10%;
        animation-duration: 8s;
    }

    .circle:nth-child(3) {
        width: 80px;
        height: 80px;
        bottom: 25%;
        left: 8%;
        animation-duration: 5s;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }
    }
</style>

<div class="login-container">

    <!-- Animated Background -->
    <div class="circle"></div>
    <div class="circle"></div>
    <div class="circle"></div>

    <div class="login-card card">

        <div class="card-header text-center">
            <h3>Welcome Back</h3>
            <p class="text-light mb-0">Login to continue</p>
        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form method="post" action="/Auth/Login">

                <div class="mb-4">
                    <label class="form-label">Email Address</label>
                    <input type="email"
                           name="email"
                           class="form-control"
                           placeholder="Enter your email"
                           required />
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password"
                           name="password"
                           class="form-control"
                           placeholder="Enter your password"
                           required />
                </div>

                <button type="submit" class="btn btn-login w-100 text-white">
                    Login
                </button>

            </form>

        </div>

        <div class="card-footer">
            Don't have an account?
            <a href="/Auth/Register">Register Here</a>
        </div>

    </div>

</div>