@using ProductModel = EcommerceWeb.Models.Product.Product
@using EcommerceWeb.Models.Product
@model List<ProductModel>

@{
    ViewBag.Title = "Shop";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var productImages = ViewBag.ProductImages as Dictionary<int, List<ProductImage>>;
    var cartItems = ViewBag.CartItems as List<EcommerceWeb.Models.Cart.Cart>;
    int cartCount = cartItems?.Count ?? 0;
    decimal cartTotal = cartItems?.Sum(x => x.Subtotal) ?? 0;
}

<div class="container mt-4" style="padding-bottom:100px;">
    <h2 class="mb-4">🛍️ Shop</h2>

    @if (TempData["CartSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            ✅ @TempData["CartSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["CartError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            ❌ @TempData["CartError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in Model)
        {
            var images = productImages != null && productImages.ContainsKey(product.ProductId)
                ? productImages[product.ProductId] : null;

            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (images != null && images.Count > 0)
                    {
                        <div id="carousel_@product.ProductId" class="carousel slide"
                             data-bs-ride="carousel">
                            <div class="carousel-inner">
                                @for (int i = 0; i < images.Count; i++)
                                {
                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <img src="@images[i].ImagePath"
                                             class="d-block w-100"
                                             style="height:200px; object-fit:cover;" />
                                    </div>
                                }
                            </div>
                            @if (images.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button"
                                        data-bs-target="#carousel_@product.ProductId"
                                        data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button"
                                        data-bs-target="#carousel_@product.ProductId"
                                        data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center
                                    justify-content-center" style="height:200px;">
                            <span>No Image</span>
                        </div>
                    }

                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted small">@product.Description</p>
                        <p class="card-text">
                            <strong class="text-success fs-5">
                                Rs. @product.Price.ToString("N0")
                            </strong>
                        </p>
                        <p class="card-text">
                            <small class="text-muted">
                                @if (product.Stock > 0)
                                {
                                    <span class="text-success">✅ In Stock (@product.Stock)</span>
                                }
                                else
                                {
                                    <span class="text-danger">❌ Out of Stock</span>
                                }
                            </small>
                        </p>
                    </div>
                    <div class="card-footer">
                        @if (product.Stock > 0)
                        {
                            <form method="post" action="/Cart/Add">
                                <input type="hidden" name="productId"
                                       value="@product.ProductId" />
                                <div class="d-flex align-items-center gap-2">
                                    <input type="number" name="quantity" value="1"
                                           min="1" max="@product.Stock"
                                           class="form-control w-50" />
                                    <button type="submit" class="btn btn-primary w-50">
                                        🛒 Add to Cart
                                    </button>
                                </div>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100" disabled>
                                Out of Stock
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Sticky Bottom Cart Bar -->
@if (cartCount > 0)
{
    <div class="fixed-bottom bg-dark text-white py-3 px-4 shadow-lg"
         style="z-index:1050;">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-primary fs-6">🛒 @cartCount items</span>
                <div class="d-flex gap-2">
                    @if (cartItems != null)
                    {
                        @foreach (var item in cartItems.Take(3))
{
    <div class="text-center position-relative" style="width:55px;">
        @if (!string.IsNullOrEmpty(item.ImagePath))
        {
            <img src="@item.ImagePath"
                 style="width:40px; height:40px; object-fit:cover; border-radius:8px;" />
        }
        <div style="font-size:10px;">
            @item.ProductName.Substring(0, Math.Min(6, item.ProductName.Length))...
        </div>
        <!-- Remove button -->
      <form method="post" action="/Cart/Remove" style="display:inline;">
    <input type="hidden" name="cartId" value="@item.CartId" />
    <input type="hidden" name="returnUrl" value="shop" />
    <button type="submit"
            class="position-absolute top-0 end-0 btn btn-danger rounded-circle p-0"
            style="width:18px; height:18px; font-size:10px; line-height:1;">
        ✕
    </button>
</form>
    </div>
}
                        @if (cartItems.Count > 3)
                        {
                            <div class="text-center d-flex align-items-center">
                                <span class="text-muted">+@(cartItems.Count - 3) more</span>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <strong class="fs-5">Rs. @cartTotal.ToString("N0")</strong>
                <a href="/Order/Checkout" class="btn btn-success btn-lg">
                    Checkout →
                </a>
                <a href="/Cart/Index" class="btn btn-outline-light">
                    View Cart
                </a>
            </div>
        </div>
    </div>
}