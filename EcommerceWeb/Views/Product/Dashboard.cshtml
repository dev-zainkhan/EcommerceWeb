@using ProductModel = EcommerceWeb.Models.Product.Product
@using EcommerceWeb.Models.Product
@model List<ProductModel>

@{
    ViewBag.Title = "Seller Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var productImages = ViewBag.ProductImages as Dictionary<int, List<ProductImage>>;
    var totalStock = Model.Sum(p => p.Stock);
    var totalValue = Model.Sum(p => p.Price * p.Stock);
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-end mb-4 gap-2">
        <div>
            <h1 class="page-title mb-1">My Products</h1>
            <p class="page-sub mb-0">Manage your store inventory</p>
        </div>
        <a href="/Product/Add" class="btn btn-success btn-lg">+ Add New Product</a>
    </div>

    <!-- Stat cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card"><div class="card-body">
                <div class="text-muted small">Total products</div>
                <div class="fw-bold" style="font-size:1.8rem;">@Model.Count</div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card"><div class="card-body">
                <div class="text-muted small">Units in stock</div>
                <div class="fw-bold" style="font-size:1.8rem;">@totalStock</div>
            </div></div>
        </div>
        <div class="col-md-4">
            <div class="card"><div class="card-body">
                <div class="text-muted small">Inventory value</div>
                <div class="fw-bold text-success" style="font-size:1.8rem;">Rs. @totalValue.ToString("N0")</div>
            </div></div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card"><div class="card-body text-center py-5">
            <div style="font-size:3rem;">📦</div>
            <h4 class="mt-3">No products yet</h4>
            <p class="text-muted">Click <strong>Add New Product</strong> to list your first item.</p>
            <a href="/Product/Add" class="btn btn-success">+ Add New Product</a>
        </div></div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 product-grid">
            @foreach (var product in Model)
            {
                var images = productImages != null && productImages.ContainsKey(product.ProductId)
                    ? productImages[product.ProductId] : null;

                <div class="col">
                    <div class="card h-100">
                        @if (images != null && images.Count > 0)
                        {
                            <div id="carousel_@product.ProductId" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner">
                                    @for (int i = 0; i < images.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <img src="@images[i].ImagePath" class="d-block w-100"
                                                 style="height:230px; object-fit:cover;" alt="@product.Name" />
                                        </div>
                                    }
                                </div>
                                @if (images.Count > 1)
                                {
                                    <button class="carousel-control-prev" type="button"
                                            data-bs-target="#carousel_@product.ProductId" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button"
                                            data-bs-target="#carousel_@product.ProductId" data-bs-slide="next">
                                        <span class="carousel-control-next-icon"></span>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center text-muted"
                                 style="height:230px; background:#eef1f6;">
                                <span>No Image</span>
                            </div>
                        }

                        <div class="card-body">
                            <h5 class="card-title mb-1">@product.Name</h5>
                            <p class="card-text text-muted small">
                                @(string.IsNullOrWhiteSpace(product.Description)
                                    ? "" : (product.Description.Length > 80 ? product.Description.Substring(0, 80) + "…" : product.Description))
                            </p>
                            <div class="d-flex align-items-center justify-content-between mt-2">
                                <strong class="text-success" style="font-size:1.3rem;">Rs. @product.Price.ToString("N0")</strong>
                                <span class="badge @(product.Stock > 0 ? "" : "bg-danger")"
                                      style="@(product.Stock > 0 ? "background:var(--brand-50);color:var(--brand-700);" : "")">
                                    Stock: @product.Stock
                                </span>
                            </div>
                        </div>
                        <div class="card-footer text-muted">
                            <small>Added @product.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
