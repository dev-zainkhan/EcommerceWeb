@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="page-title mb-4">Privacy Policy</h1>
            <div class="card"><div class="card-body p-4 p-md-5">
                <p class="text-muted">ShopSphere is a demonstration e-commerce application. This page outlines how the demo handles your data.</p>

                <h5 class="mt-4">Information we store</h5>
                <p class="text-muted">Your name, email, role and an optional profile image. Passwords are never stored in plain text — they are hashed with BCrypt.</p>

                <h5 class="mt-4">How it is used</h5>
                <p class="text-muted">Account information is used solely to authenticate you, display your profile, and process orders within the application.</p>

                <h5 class="mt-4">Images</h5>
                <p class="text-muted">Product and profile images are uploaded to cloud object storage (Amazon S3) and served over HTTPS.</p>

                <p class="text-muted mb-0 mt-4"><em>This is a portfolio/demo project and not intended for production use with real personal data.</em></p>
            </div></div>
        </div>
    </div>
</div>
