<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · ShopSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EcommerceWeb.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var userName = Context.Session.GetString("UserName");
        var userRole = Context.Session.GetString("UserRole");
        var homeHref = userRole == "Seller" ? "/Product/Dashboard" : "/Product/Index";
    }
    <header>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" href="@homeHref">
                    <span style="font-size:1.4rem;">🛍️</span> ShopSphere
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        @if (userName != null)
                        {
                            @if (userRole == "Seller")
                            {
                                <li class="nav-item"><a class="nav-link" href="/Product/Dashboard">My Products</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Product/Add">+ Add Product</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" href="/Product/Index">Shop</a></li>
                                <li class="nav-item"><a class="nav-link" href="/Cart/Index">🛒 Cart</a></li>
                            }
                            <li class="nav-item">
                                <a class="nav-link d-flex align-items-center gap-2" href="/Profile/Index">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                          style="width:30px;height:30px;background:var(--brand-100);color:var(--brand-700);font-weight:700;">
                                        @userName.Substring(0,1).ToUpper()
                                    </span>
                                    @userName
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-secondary btn-sm ms-lg-2" href="/Auth/Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" href="/Auth/Login">Login</a></li>
                            <li class="nav-item"><a class="btn btn-primary btn-sm ms-lg-2" href="/Auth/Register">Get Started</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; 2026 <strong>ShopSphere</strong> · Built with ASP.NET Core</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
